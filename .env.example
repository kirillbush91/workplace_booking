BOOKING_URL=https://lemana.simple-office-web.liis.su/

# Credentials. Leave empty if storage state already contains a valid session.
USERNAME=
PASSWORD=

# Target values.
TARGET_OFFICE=Office Name
TARGET_SEAT=17

# Pre-login actions (useful for SSO entry button on landing page).
PRE_LOGIN_CLICK_SELECTORS=
PRE_LOGIN_CLICK_TEXTS=Log in using SAML|Sign in
PRE_LOGIN_CLICK_TIMEOUT_MS=4000
# OTP: if OTP_CODE_VALUE is empty, bot can request OTP via Telegram and wait for your reply.
OTP_CODE_INPUT_SELECTOR=
OTP_CODE_VALUE=
OTP_WAIT_TIMEOUT_MS=120000

# Browser settings.
HEADLESS=true
DEFAULT_TIMEOUT_MS=30000
UI_PAUSE_MS=500

# Retry settings for one run.
RETRY_ATTEMPTS=3
RETRY_DELAY_SEC=30

# Run once or run forever in intervals.
RUN_MODE=once
RUN_INTERVAL_MINUTES=30

# Optional UI selectors.
PAGE_READY_SELECTOR=
LOGIN_USERNAME_SELECTORS=input[type="email"]|input[name="username"]|input[id*="user"]|input[type="text"]
LOGIN_PASSWORD_SELECTORS=input[type="password"]
LOGIN_SUBMIT_SELECTORS=button[type="submit"]|input[type="submit"]|button:has-text("Sign in")|button:has-text("Log in")|button:has-text("Continue")
LOGIN_SUCCESS_SELECTOR=

# Office selection.
OFFICE_CHOOSE_SELECTOR=
OFFICE_OPEN_SELECTOR=
OFFICE_OPTION_SELECTOR_TEMPLATE=
# Wait for map load after office click.
OFFICE_MAP_READY_SELECTOR=
OFFICE_MAP_WAIT_TIMEOUT_MS=60000
OFFICE_MAP_EXTRA_WAIT_MS=0
OFFICE_MAP_LOADING_SELECTORS=
OFFICE_MAP_LOADING_WAIT_TIMEOUT_MS=60000

# Booking parameter panel.
BOOKING_PARAMS_OPEN_SELECTOR=
BOOKING_PARAMS_APPLY_SELECTOR=
BOOKING_PARAMS_CLOSE_SELECTOR=
BOOKING_DATE_INPUT_SELECTOR=
BOOKING_DATE_DAY_SELECTOR_TEMPLATE=
BOOKING_CALENDAR_NEXT_SELECTOR=
BOOKING_DATE_VALUE=
BOOKING_DATE_OFFSET_DAYS=7
# If BOOKING_DATE_VALUE/BOOKING_DATE_OFFSET_DAYS are empty, bot uses range mode.
BOOKING_RANGE_DAYS=7
BOOKING_INCLUDE_TODAY=true
BOOKING_SKIP_WEEKENDS=false
BOOKING_PER_DATE_ATTEMPTS=2
BOOKING_DATE_FORMAT=%d.%m.%Y
BOOKING_TYPE_SELECTOR=
BOOKING_TYPE_OPTION_SELECTOR=
BOOKING_TYPE_VALUE=
BOOKING_TIME_FROM_SELECTOR=
BOOKING_TIME_TO_SELECTOR=
BOOKING_TIME_FROM=09:00
BOOKING_TIME_TO=18:00

# Seat and booking submit.
SEAT_SEARCH_SELECTOR=
SEAT_SELECTOR_TEMPLATE=
SEAT_CANVAS_SELECTOR=
SEAT_CANVAS_INDEX=
SEAT_CANVAS_X=
SEAT_CANVAS_Y=
BOOK_BUTTON_SELECTOR=
BOOK_BUTTON_TEXTS=Book|Reserve|Confirm
SUCCESS_SELECTOR=
SUCCESS_CLOSE_SELECTOR=
SUCCESS_TEXT=

# Candidate selectors for lemana.simple-office-web.liis.su (verify with scripts/capture_selectors_browser.js):
# OFFICE_CHOOSE_SELECTOR=a[href*="/map?office_id=f26721e7-a329-4cd0-8c10-ae002bcdfb4c"]
# OFFICE_OPEN_SELECTOR=.select-offices-antd-unstyled .ant-select-selector
# OFFICE_OPTION_SELECTOR_TEMPLATE=.select-office-dropdown-antd-unstyled .ant-select-item-option:has-text("{office}")
# SEAT_SEARCH_SELECTOR=input[placeholder="Search..."]
# BOOK_BUTTON_SELECTOR=button:has-text("Book a place")
# SUCCESS_TEXT=Successfully booked!

# Local state.
STORAGE_STATE_PATH=.state/storage_state.json
SCREENSHOT_DIR=.state/screenshots

# Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=INFO
