# Local-only secrets and machine-specific overrides.
# Repo loads `.env.shared` first, then `.env`.
# Keep actual `.env` out of git.

# Secrets
USERNAME=
PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_FROM=
EMAIL_SMTP_TO=

# Optional one-time OTP override. Usually leave empty and reply via Telegram.
OTP_CODE_VALUE=

# Optional Telegram transport via private proxy over AmneziaWG/WireGuard.
TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_URL=http://10.8.0.2:3128

# Optional email fallback for critical events only.
EMAIL_FALLBACK_ENABLED=false
EMAIL_SMTP_STARTTLS=true

# Optional daily Telegram transport health check.
HEALTHCHECK_ENABLED=false
HEALTHCHECK_TIME_LOCAL=21:00

# Typical local overrides for debugging
HEADLESS=false
RUN_MODE=once
LOG_LEVEL=DEBUG

# Optional manual test overrides
BOOKING_DATE_VALUES=
